NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# サーバー専用。NEXT_PUBLIC_ を付けない（クライアントに絶対露出させない）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 管理画面(/admin)にログインを許可するメールアドレス（カンマ区切り、任意）。
# 他アプリとSupabaseプロジェクトを共用している場合は必ず設定すること。
# 未設定の場合、そのSupabaseプロジェクトにログインできる全アカウントが管理者になれる。
ADMIN_EMAILS=you@example.com

# 任意: 簡易アクセス解析
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id_here

# 投稿フォームの写真アップロード先（Google Drive）。
# サービスアカウントを作成し、アップロード先フォルダをそのサービスアカウントのメールアドレスに
# 「編集者」として共有してから設定する。未設定の間は写真アップロードなしで投稿できる。
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# JSONキーの private_key の値をそのまま貼り付ける（\n はそのままでOK。コード側で変換する）
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# 住所からの緯度経度自動取得（Geocoding API）用。ブラウザ用のNEXT_PUBLIC_GOOGLE_MAPS_API_KEYとは
# 別のキーを、アプリケーションの制限「なし」・APIの制限「Geocoding API」のみで発行する。
# 未設定の間は緯度経度の自動取得なしで投稿の承認が可能（要手動入力）。
GOOGLE_GEOCODING_API_KEY=your_server_side_geocoding_api_key_here
